# Container identity and image
# Leave CONTAINER_NAME and HOSTNAME as-is unless you run more than one server on the same host
CONTAINER_NAME=windrose
HOSTNAME=windrose
IMAGE_REPOSITORY=ghcr.io/uberdudepl/windrose-dedicated-server-docker
IMAGE_TAG=v1.0.1

# Host permissions
PUID=1000
PGID=1000

# Steam / game
STEAM_LOGIN=anonymous
STEAM_PASS=
WINDROSE_APP_ID=4129620
UPDATE_ON_START=true
GENERATE_SETTINGS=true

# ServerDescription.json patching
INVITE_CODE=
SERVER_NAME=My Windrose Server
SERVER_NOTE=Friendly co-op server
SERVER_PASSWORD=
MAX_PLAYERS=4
P2P_PROXY_ADDRESS=127.0.0.1

# Networking
PORT=7777
QUERYPORT=7778
MULTIHOME=0.0.0.0
